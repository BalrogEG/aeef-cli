{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeef.dev/schemas/gate-decision.schema.json",
  "title": "GateDecision v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["gate_id", "stage", "criteria_results", "decision", "required_human_approver", "evidence_refs"],
  "properties": {
    "gate_id": { "type": "string", "minLength": 3 },
    "stage": { "type": "string", "minLength": 2 },
    "criteria_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion", "passed", "note"],
        "properties": {
          "criterion": { "type": "string" },
          "passed": { "type": "boolean" },
          "note": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "decision": { "type": "string", "enum": ["pass", "fail", "conditional"] },
    "required_human_approver": { "type": ["string", "null"] },
    "evidence_refs": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
  }
}
